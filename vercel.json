{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/live",
      "destination": "/api/live.ts"
    },
    {
      "source": "/api/team",
      "destination": "/api/team.ts"
    },
    {
      "source": "/api/match-details",
      "destination": "/api/match-details.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
